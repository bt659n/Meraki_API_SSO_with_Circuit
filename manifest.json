{
  "manifest_version": 3,
  "name": "Meraki API SSO LOGIN",
  "version": "4.4",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "*://*.meraki.com/*",
    "*://*.meraki.cn/*",
    "*://*.meraki.ca/*",
    "*://*.meraki.in/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" }
}